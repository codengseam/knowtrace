# 云脉·智诊伴学 · 阿里云百炼平台配置

# 阿里云百炼 / DashScope API Key（必填）
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 百炼 RAG 应用 ID（题库检索应用，必填）
DASHSCOPE_RAG_APP_ID=your-rag-app-id-here

# 主模型分工
LLM_MODEL=qwen3-max
LLM_MULTIMODAL_MODEL=qwen3-omni
LLM_EDGE_FALLBACK_MODEL=qwen3-1.5b

# FunASR 语音合成 App Key（家长端学情周报）
FUNASR_APP_KEY=your-funasr-app-key-here

# 百炼 API 入口
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：Mock 模式（不调用 LLM，使用预设响应，用于本地测试）
LLM_MOCK=

# 可选：Web 服务端口
WEB_PORT=8080

# 可选：RAG 检索后端切换（local=本地 JSON 题库占位 / bailian=百炼 RAG 应用）
# 默认 local，Phase 2 搭建百炼 RAG 应用后改为 bailian
RETRIEVER_BACKEND=local
