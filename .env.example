# 大模型 API 配置（支持任意 OpenAI 兼容接口，如 DashScope、SiliconFlow、OpenAI 等）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max-latest

# 可选：设置为 1 时使用占位生成模式（无需 API Key，仅用于测试界面）
# DEEP_READING_STUB=1

# Mock 模式：不调用 LLM API，使用预设响应（用于测试）
DEEP_READING_MOCK=

# 可选：Web 服务端口（默认 8080，避开 macOS AirPlay 占用的 5000）
# DEEP_READING_WEB_PORT=8080

# Obsidian Vault 的本地绝对路径
# 示例：/Users/yourname/Documents/Obsidian Vault
OBSIDIAN_VAULT_PATH=

# 可选：Web 搜索 API Key（Google Custom Search）
GOOGLE_SEARCH_API_KEY=
GOOGLE_CX=
